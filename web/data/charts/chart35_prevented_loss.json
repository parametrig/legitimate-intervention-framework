{
  "chart": {
    "title": {
      "text": "Total Prevented Loss by Authority"
    },
    "tooltip": {
      "trigger": "axis",
      "valueFormatter": "${value}B"
    },
    "xAxis": {
      "type": "category",
      "data": [
        "Signer Set",
        "Delegated Body",
        "Governance"
      ]
    },
    "yAxis": {
      "type": "value",
      "name": "Capital Saved ($B)"
    },
    "series": [
      {
        "type": "bar",
        "data": [
          {
            "value": 1.3,
            "itemStyle": {
              "color": "#2563EB"
            }
          },
          {
            "value": 1.15,
            "itemStyle": {
              "color": "#16A34A"
            }
          },
          {
            "value": 0.25,
            "itemStyle": {
              "color": "#7C3AED"
            }
          }
        ],
        "label": {
          "show": true,
          "position": "top",
          "formatter": "${value}B"
        }
      }
    ]
  }
}